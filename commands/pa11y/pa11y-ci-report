#!/bin/sh
#ddev-generated
## Description: Run pa11y-ci and generate an HTML report in reports/<timestamp>/
## Usage: pa11y-ci-report [environment|url] [args]
## Example: "ddev pa11y-ci-report local" or "ddev pa11y-ci-report https://example.com"
## ExecRaw: true

PA11Y_TESTS_PATH="/src/tests"
DEFAULT_ENV="${PA11Y_DEFAULT_ENV:-local}"

FOLDER=$(date +%Y%m%d_%H%M%S)
REPORT_DIR="/src/reports/$FOLDER"

ENV="${1:-$DEFAULT_ENV}"
if [ -d "$PA11Y_TESTS_PATH/$ENV" ] && [ -f "$PA11Y_TESTS_PATH/$ENV/pa11yci.json" ]; then
  [ -n "$1" ] && shift
  CONFIG_FILE="$PA11Y_TESTS_PATH/$ENV/pa11yci.json"
elif [ -n "$1" ]; then
  CONFIG_FILE=""
else
  echo "Usage: ddev pa11y-ci-report [environment|url] [args]"
  echo ""
  echo "Available environments:"
  find "$PA11Y_TESTS_PATH" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | xargs -I{} basename {}
  exit 1
fi

mkdir -p "$REPORT_DIR"
TMP=$(mktemp /tmp/pa11yci-XXXXXX.json)

{ [ -n "$CONFIG_FILE" ] && cat "$CONFIG_FILE" || echo '{}'; } \
  | jq --arg dest "$REPORT_DIR" '
      .defaults //= {} |
      .defaults.reporters = [
        "/usr/lib/node_modules/pa11y-ci/lib/reporters/cli.js",
        ["pa11y-ci-reporter-html", {"destination": $dest}]
      ] |
      del(.defaults.threshold)
    ' > "$TMP"

pa11y-ci -c "$TMP" "$@"
EXIT_CODE=$?
rm -f "$TMP"

echo "HTML report saved to ${PA11Y_REPORTS_PATH:-reports/pa11y}/$FOLDER/"
exit $EXIT_CODE
