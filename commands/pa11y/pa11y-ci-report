#!/bin/sh
#ddev-generated
## Description: Run pa11y-ci and generate an HTML report in reports/<url>/
## Usage: pa11y-ci-report [args]
## Example: "ddev pa11y-ci-report https://example.com"
## ExecRaw: true

FOLDER=$(date +%Y%m%d_%H%M%S)

REPORT_DIR="/home/aljibe/reports/$FOLDER"
TMP=$(mktemp /tmp/pa11yci-XXXXXX.json)

node -e "
  const fs = require('fs');
  const cfg = JSON.parse(fs.readFileSync('/home/aljibe/pa11yci.json', 'utf8'));
  cfg.defaults.reporters = [['pa11y-ci-reporter-html', { destination: '$REPORT_DIR' }]];
  fs.writeFileSync('$TMP', JSON.stringify(cfg));
"

pa11y-ci -c "$TMP" "$@"
STATUS=$?
rm -f "$TMP"

echo "HTML report saved to ${PA11Y_REPORTS_PATH:-reports/pa11y}/$FOLDER/"
exit $STATUS
