#!/bin/sh
#ddev-generated
## Description: Run pa11y-ci
## Usage: pa11y-ci [environment|url] [args]
## Example: "ddev pa11y-ci local" or "ddev pa11y-ci https://example.com"
## ExecRaw: true

PA11Y_TESTS_PATH="/home/aljibe/tests"
DEFAULT_ENV="${PA11Y_DEFAULT_ENV:-local}"

ENV="${1:-$DEFAULT_ENV}"
if [ -d "$PA11Y_TESTS_PATH/$ENV" ] && [ -f "$PA11Y_TESTS_PATH/$ENV/pa11yci.json" ]; then
  [ -n "$1" ] && shift
  pa11y-ci -c "$PA11Y_TESTS_PATH/$ENV/pa11yci.json" "$@"
elif [ -n "$1" ]; then
  pa11y-ci "$@"
else
  echo "Usage: ddev pa11y-ci [environment|url] [args]"
  echo ""
  echo "Available environments:"
  find "$PA11Y_TESTS_PATH" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | xargs -I{} basename {}
  exit 1
fi
