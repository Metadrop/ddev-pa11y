#!/bin/sh
#ddev-generated
## Description: Run pa11y
## Usage: pa11y [environment|url] [args]
## Example: "ddev pa11y local https://example.com" or "ddev pa11y https://example.com"
## ExecRaw: true

PA11Y_TESTS_PATH="/src/tests"

if [ -z "$1" ]; then
  echo "Usage: ddev pa11y <environment|url> [args]"
  echo "  environment: folder name inside tests/pa11y/ containing config.json"
  echo "  url: URL to test directly"
  echo ""
  echo "Available environments:"
  find "$PA11Y_TESTS_PATH" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | xargs -I{} basename {}
  echo ""
  pa11y
  exit 0
fi

if [ -d "$PA11Y_TESTS_PATH/$1" ] && [ -f "$PA11Y_TESTS_PATH/$1/config.json" ]; then
  ENV=$1
  shift
  pa11y -c "$PA11Y_TESTS_PATH/$ENV/config.json" "$@"
else
  pa11y -c /src/config.json "$@"
fi
